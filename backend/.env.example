PORT=4000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
JWT_SECRET=your-jwt-secret-change-me
NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_IPN_SECRET=your-nowpayments-ipn-secret
FRONTEND_URL=http://localhost:3000
GAME_SERVER_URL=ws://localhost:4001

# TRC20 Auto-Deposit System (1xBet-style)
# Generate mnemonic: node -e "require('bip39').then(b=>console.log(b.generateMnemonic(256)))"
TRON_MASTER_MNEMONIC=your-24-word-mnemonic-here
# 32+ character encryption key for private key storage (AES-256-GCM)
TRON_ENCRYPTION_KEY=change-this-to-a-32-char-secret!
# Free API key from https://www.trongrid.io/
TRONGRID_API_KEY=your-trongrid-api-key
# mainnet or shasta (testnet)
TRON_NETWORK=mainnet

# TON Auto-Deposit System
# API key from https://tonconsole.com/ (used with tonapi.io for deposit listener)
TON_API_KEY=your-tonconsole-api-key
# mainnet or testnet
TON_NETWORK=mainnet
# Sweep config (optional — auto-send USDT from user wallets to your main wallet)
TON_SWEEP_DESTINATION=your-main-ton-wallet-address
TON_HOT_WALLET_MNEMONIC=your-24-word-hot-wallet-mnemonic
# Optional: toncenter.com API key for sweep (get free from @toncenter Telegram bot)
# Without this, sweep uses rate-limited public access (fine for small user counts)
# TONCENTER_API_KEY=your-toncenter-api-key

# BEP20 (BSC) Auto-Deposit System
# Generate mnemonic: node -e "require('bip39').then(b=>console.log(b.generateMnemonic(256)))"
BSC_MASTER_MNEMONIC=your-24-word-mnemonic-here
# Free API key from https://bscscan.com/myapikey
BSCSCAN_API_KEY=your-bscscan-api-key
# mainnet or testnet
BSC_NETWORK=mainnet

# Solana (SPL) Auto-Deposit System
# Generate mnemonic: node -e "require('bip39').then(b=>console.log(b.generateMnemonic(256)))"
SOLANA_MASTER_MNEMONIC=your-24-word-mnemonic-here
# Free API key from https://dev.helius.xyz/ (optional but recommended)
HELIUS_API_KEY=your-helius-api-key
# Or custom RPC URL (optional, defaults to public mainnet)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
